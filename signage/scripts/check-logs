#!/bin/bash

BASE_LOG_DIR="/home/vers/signage/logs"
LOG_FOLDERS=("pi-check_logs" "watchdog_logs" "maintenance")

# ask user if they want today or custom date
read -rp "View logs for today? (Y/n): " use_today
use_today=${use_today:-Y}

if [[ "$use_today" =~ ^[Yy]$ ]]; then
    DATE_STR=$(date '+%Y-%m-%d')
else
    read -rp "Enter date (YYYY-MM-DD): " DATE_STR
    if [[ ! $DATE_STR =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
        echo "Invalid date format" >&2
        exit 1
    fi
fi

echo ""
echo "Fetching logs for date: $DATE_STR"
echo "===================================================="

# iterate through log folders
for folder in "${LOG_FOLDERS[@]}"; do
    LOG_DIR="$BASE_LOG_DIR/$folder"
    if [[ ! -d "$LOG_DIR" ]]; then
        echo "Folder not found: $LOG_DIR"
        continue
    fi

    log_files=( "$LOG_DIR"/*"$DATE_STR"*.log )
    if [ ${#log_files[@]} -eq 0 ]; then
        echo "No log files found in $folder for $DATE_STR"
        continue
    fi

    # display logs
    for logfile in "${log_files[@]}"; do
        echo ""
        echo "FOLDER: $folder | FILE: $(basename "$logfile")"
        echo "--------------------------------------------------"

        # highlight common issues
        grep --color=always -E "ERROR|FAIL|CRASH|$" "$logfile"
    done
done

echo ""
echo "==================== END OF LOG =================="