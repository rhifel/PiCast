#!/bin/bash

# ENV (REQUIRED FOR X COMMANDS)
export DISPLAY=:0
export XAUTHORITY="$HOME/.Xauthority"

# PATHS
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && cd .. && pwd)"
CONFIG_FILE="$BASE_DIR/config/config.env"
LOG_DIR="$BASE_DIR/logs/watchdog_logs"
DATE_STR=$(date '+%Y-%m-%d')
LOG_FILE="$LOG_DIR/watchdog_${DATE_STR}.log"

CURL_TIMEOUT=5
FAIL_THRESHOLD=2
FAIL_COUNT_FILE="$BASE_DIR/.watchdog_fail_count"

mkdir -p "$LOG_DIR"

# LOG FUNCTION
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

# LOAD CONFIG
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
else
    log "ERROR: Config file not found: $CONFIG_FILE"
    exit 1
fi

# GET ENDPOINT
ENDPOINT="${ENDPOINT:-${URL:-}}"

if [ -z "$ENDPOINT" ]; then
    log "ERROR: No ENDPOINT or URL found in config.env"
    exit 1
fi

# INIT FAIL COUNT
if [ ! -f "$FAIL_COUNT_FILE" ]; then
    echo "0" > "$FAIL_COUNT_FILE"
fi

read_fail() {
    cat "$FAIL_COUNT_FILE" 2>/dev/null || echo "0"
}

write_fail() {
    echo "$1" > "$FAIL_COUNT_FILE"
}

log "===================================================="
log "WATCHDOG STARTED"
log "Endpoint: $ENDPOINT"

# CHECK CHROMIUM PROCESS
if ! pgrep -f chromium >/dev/null 2>&1; then
    log "CRASH: Chromium is not running"
    log "ACTION: Killing leftover processes"

    pkill -f chromium 2>/dev/null
    write_fail 0

    log "WAIT: letting X session restart Chromium"
    log "WATCHDOG FINISHED"
    exit 0
else
    log "Chromium status: RUNNING"
fi

# CHECK ENDPOINT
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" --max-time "$CURL_TIMEOUT" "$ENDPOINT")

if [[ "$HTTP_CODE" =~ ^[23] ]]; then
    log "Endpoint status: OK (HTTP $HTTP_CODE)"

    FAILS=$(read_fail)

    if [ "$FAILS" -ge 1 ]; then
        log "RECOVERY: Reloading Chromium"

        # try reload active Chromium window
        xdotool search --onlyvisible --class chromium windowactivate key Ctrl+r 2>/dev/null

        # fallback: just send Ctrl+R globally
        xdotool key Ctrl+r 2>/dev/null
    fi

    write_fail 0

else
    FAILS=$(read_fail)
    FAILS=$((FAILS + 1))
    write_fail "$FAILS"

    log "FAIL: Endpoint unreachable or bad response (HTTP $HTTP_CODE)"
    log "Failure count: $FAILS"

    if [ "$FAILS" -ge "$FAIL_THRESHOLD" ]; then
        log "ACTION: Restarting Chromium (kill only)"

        pkill -f chromium 2>/dev/null
        sleep 3

        write_fail 0
    else
        log "Waiting for next check before restart"
    fi
fi

log "WATCHDOG FINISHED"
log "===================================================="
exit 0